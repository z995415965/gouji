<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/view_floating_card_counter.xml: Floating window layout -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#80000000"
    android:padding="4dp">

    <!-- Floating Ball Icon -->
    <ImageView
        android:id="@+id/ivFloatingBall"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_mylocation"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:layout_gravity="center"
        android:contentDescription="记牌器" />

    <!-- Card Count Panel (Hidden by default) -->
    <ScrollView
        android:id="@+id/cardCountPanel"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="#EEEEEE"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvCardCounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textSize="12sp"
            android:textColor="#424242" />
    </ScrollView>

</LinearLayout>
